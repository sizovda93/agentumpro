# ===========================================
# Agentum Pro — Environment Variables
# ===========================================
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
#
# НИКОГДА не коммитьте .env в Git!
# ===========================================

# PostgreSQL
POSTGRES_DB=agentum
POSTGRES_USER=agentum
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# Database URL (для Prisma)
# В Docker: postgresql://agentum:PASSWORD@db:5432/agentum
# Локально: postgresql://agentum:PASSWORD@localhost:5432/agentum
DATABASE_URL=postgresql://agentum:CHANGE_ME_TO_STRONG_PASSWORD@db:5432/agentum

# JWT Secret — случайная строка минимум 32 символа
# Сгенерировать: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48

# Директория для загрузок
UPLOAD_DIR=/data/uploads

# Админ (для seed-скрипта)
ADMIN_EMAIL=admin@agentum-pro.ru
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
